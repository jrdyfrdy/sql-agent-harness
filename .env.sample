# ==========================================
# LLM Routing & Configuration
# ==========================================

# The LLM provider to use. 
# Accepted values: gemini, openai, anthropic, ollama.
# Default: gemini.
LLM_PROVIDER=ollama

# The specific model to use for the chosen provider.
# Examples: gemini-1.5-pro, gpt-4o-mini, claude-3-5-sonnet-latest, llama3.1.
# If left blank, the app will assign a smart default based on the chosen LLM_PROVIDER.
LLM_MODEL=llama3.1

# Controls the randomness of the model's output. 
# Recommended to keep at 0.0 for deterministic SQL generation.
# Default: 0.0.
LLM_TEMPERATURE=0.0

# ==========================================
# Provider-Specific Settings & API Keys
# ==========================================

# Required if LLM_PROVIDER=gemini.
GOOGLE_API_KEY=

# Required if LLM_PROVIDER=openai.
OPENAI_API_KEY=

# Optional: Override the default OpenAI base URL (useful for OpenAI-compatible local APIs).
# OPENAI_BASE_URL=

# Required if LLM_PROVIDER=anthropic.
ANTHROPIC_API_KEY=

# Required if LLM_PROVIDER=ollama. Points to your local or remote Ollama instance.
# Default: http://localhost:11434.
OLLAMA_BASE_URL=http://localhost:11434

# ==========================================
# Database Configuration
# ==========================================

# The file path to your DuckDB database file.
# Default: ./ecommerce.db (relative to the project root).
DB_PATH=./ecommerce.db

# ==========================================
# Application / Server Configuration
# ==========================================

# The title of the FastAPI application shown in the generated API docs.
# Default: Text-to-SQL Agent.
APP_TITLE=Text-to-SQL Agent

# The version of the FastAPI application.
# Default: 0.1.0.
APP_VERSION=0.1.0

# The host address where the Uvicorn server will run.
# Default: 127.0.0.1.
APP_HOST=127.0.0.1

# The port where the Uvicorn server will listen.
# Default: 8000.
APP_PORT=8000

# Enables hot-reloading for the Uvicorn server. Keep false for production, set to true for development.
# Accepted values to enable: 1, true, yes, on (case-insensitive).
# Default: false.
APP_RELOAD=false